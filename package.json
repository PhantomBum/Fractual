{
  "name": "fractual",
  "version": "2.8.2",
  "packageManager": "npm@11.16.0",
  "description": "A polished, animated, purpose-free desktop interface.",
  "author": "Kyro744",
  "discordClientId": "1528564601350918284",
  "engines": {
    "node": ">=22.12.0"
  },
  "repository": "https://github.com/PhantomBum/Fractual",
  "homepage": "https://github.com/PhantomBum/Fractual",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "check": "node --check main.js && node --check preload.js && node --check src/app.js && node test.js",
    "dist:win": "electron-builder --win nsis --publish never",
    "publish:win": "electron-builder --win nsis --publish always"
  },
  "devDependencies": {
    "electron": "^37.2.3",
    "electron-builder": "^26.15.3",
    "jsdom": "^26.1.0"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.3.0",
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.8.9",
    "lucide": "^1.24.0"
  },
  "build": {
    "appId": "com.kyro744.fractual",
    "productName": "Fractual",
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "artifactName": "Fractual-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Fractual"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "PhantomBum",
        "repo": "Fractual",
        "releaseType": "release"
      }
    ]
  }
}
